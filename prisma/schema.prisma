generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model Usuario {
  id      Int    @id @default(autoincrement())
  nome    String
  usuario String @unique
  senha   String
  nivel   String

  @@map("usuarios")
}

model Navio {
  id            Int     @id @default(autoincrement())
  nome          String
  eh_perecivel  Boolean
  containers    Int
  peso          Float
  valor_total   Float

  @@map("estoque")
}